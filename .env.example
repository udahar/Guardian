# Guardian — Environment Configuration
# Copy this to .env and fill in your values. Never commit .env to git.

# PostgreSQL (optional — Guardian can run without DB)
GUARDIAN_DB_ENABLED=true
GUARDIAN_DB_HOST=localhost
GUARDIAN_DB_PORT=5432
GUARDIAN_DB_NAME=your_db_name
GUARDIAN_DB_USER=your_db_user
GUARDIAN_DB_PASSWORD=your_db_password

# Qdrant (optional)
GUARDIAN_QDRANT_URL=http://localhost:6333

# Telegram alerts (optional — Guardian works without these, just no Telegram notifications)
GUARDIAN_TELEGRAM_BOT_TOKEN=your_bot_token_here
GUARDIAN_TELEGRAM_CHAT_ID=your_chat_id_here

# Monitoring thresholds (optional — these are the defaults)
GUARDIAN_WSL_MEMORY_THRESHOLD=60
GUARDIAN_WINDOWS_MEMORY_WARNING=70
GUARDIAN_WINDOWS_MEMORY_CRITICAL=85
GUARDIAN_WINDOWS_DISK_WARNING=80
GUARDIAN_WINDOWS_DISK_CRITICAL=90
GUARDIAN_CHECK_INTERVAL=60
GUARDIAN_LOG_LEVEL=INFO
GUARDIAN_AUTO_HEAL=true
GUARDIAN_DRY_RUN=false
